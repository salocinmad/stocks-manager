{
  "name": "stocks-manager",
  "version": "0.9.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "bun server.js",
    "dev": "bun --watch server.js",
    "init-admin": "bun scripts/initAdmin.js",
    "reset-admin-password": "bun scripts/resetAdminPassword.js",
    "check-indexes": "bun scripts/normalize-indexes.js",
    "normalize-indexes": "bun scripts/normalize-indexes.js --apply",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "drizzle-orm": "^0.32.0",
    "express": "4.21.2",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "7.0.11",
    "pg": "^8.12.0",
    "yahoo-finance2": "3.10.2",
    "multer": "1.4.5-lts.2",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.0"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "drizzle-kit": "^0.24.0"
  }
}